// ─── Event Feed & AI Editor ───────────────────────────────────────────────

model FeedCategory {
  id          String    @id @default(uuid()) @db.Uuid
  slug        String    @unique
  name        String
  description String?
  coverImage  String?   @map("cover_image")
  sortOrder   Int       @default(0) @map("sort_order")
  isActive    Boolean   @default(true) @map("is_active")
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  posts FeedPost[]

  @@index([isActive])
  @@index([deletedAt])
  @@map("feed_categories")
}

model FeedPost {
  id                 String            @id @default(uuid()) @db.Uuid
  slug               String            @unique
  title              String
  headline           String?
  summary            String
  content            String            @db.Text
  excerpt            String?
  contentType        FeedPostType      @map("content_type")
  status             FeedPostStatus    @default(discovered)
  editorialStage     FeedEditorialStage? @map("editorial_stage")
  coverImage         String            @map("cover_image")
  authorName         String            @default("BiletFeed Editör") @map("author_name")
  authorId           String?           @map("author_id") @db.Uuid
  readingTimeMinutes Int               @default(3) @map("reading_time_minutes")
  viewCount          Int               @default(0) @map("view_count")
  likeCount          Int               @default(0) @map("like_count")
  commentCount       Int               @default(0) @map("comment_count")
  bookmarkCount      Int               @default(0) @map("bookmark_count")
  shareCount         Int               @default(0) @map("share_count")
  sourceUrl          String?           @map("source_url")
  sourceName         String?           @map("source_name")
  sourceAttribution  String?           @map("source_attribution")
  aiProvider         String?           @map("ai_provider")
  aiModel            String?           @map("ai_model")
  aiMetadata         Json              @default("{}") @map("ai_metadata")
  duplicateOfId      String?           @map("duplicate_of_id") @db.Uuid
  reviewNotes        String?           @map("review_notes")
  seo                Json              @default("{}")
  tags               String[]          @default([])
  isFeatured         Boolean           @default(false) @map("is_featured")
  trendingScore      Float             @default(0) @map("trending_score")
  publishedAt        DateTime?         @map("published_at")
  feedCategoryId     String?           @map("feed_category_id") @db.Uuid
  eventId            String?           @map("event_id") @db.Uuid
  organizerId        String?           @map("organizer_id") @db.Uuid
  cityId             String?           @map("city_id") @db.Uuid
  venueId            String?           @map("venue_id") @db.Uuid
  artistName         String?           @map("artist_name")
  deletedAt          DateTime?         @map("deleted_at")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  author       User?         @relation("FeedPostAuthor", fields: [authorId], references: [id])
  feedCategory FeedCategory? @relation(fields: [feedCategoryId], references: [id])
  event        Event?        @relation(fields: [eventId], references: [id])
  organizer    Organizer?    @relation(fields: [organizerId], references: [id])
  city         City?         @relation(fields: [cityId], references: [id])
  venue        Venue?        @relation(fields: [venueId], references: [id])
  duplicateOf  FeedPost?     @relation("FeedDuplicates", fields: [duplicateOfId], references: [id])
  duplicates   FeedPost[]    @relation("FeedDuplicates")
  media        FeedMedia[]
  views        FeedView[]
  likes        FeedLike[]
  bookmarks    FeedBookmark[]
  comments     FeedComment[]
  queueItems   FeedEditorialQueue[]

  @@index([status])
  @@index([contentType])
  @@index([publishedAt])
  @@index([isFeatured])
  @@index([trendingScore])
  @@index([eventId])
  @@index([feedCategoryId])
  @@index([deletedAt])
  @@map("feed_posts")
}

model FeedMedia {
  id        String        @id @default(uuid()) @db.Uuid
  postId    String        @map("post_id") @db.Uuid
  type      FeedMediaType
  url       String
  thumbnail String?
  alt       String?
  caption   String?
  sortOrder Int           @default(0) @map("sort_order")
  featured  Boolean       @default(false)
  createdAt DateTime      @default(now()) @map("created_at")

