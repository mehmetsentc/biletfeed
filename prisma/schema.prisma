  @@unique([postId, userId])
  @@index([postId])
  @@map("feed_bookmarks")
}

model FeedComment {
  id        String    @id @default(uuid()) @db.Uuid
  postId    String    @map("post_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  body      String
  isHidden  Boolean   @default(false) @map("is_hidden")
  parentId  String?   @map("parent_id") @db.Uuid
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  post   FeedPost      @relation(fields: [postId], references: [id], onDelete: Cascade)
  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent FeedComment?  @relation("FeedCommentReplies", fields: [parentId], references: [id])
  replies FeedComment[] @relation("FeedCommentReplies")

  @@index([postId])
  @@index([userId])
  @@index([deletedAt])
  @@map("feed_comments")
}

model FeedEditorialQueue {
  id            String            @id @default(uuid()) @db.Uuid
  sourceUrl     String            @map("source_url")
  sourceTitle   String            @map("source_title")
  sourceSnippet String?           @map("source_snippet")
  sourceName    String?           @map("source_name")
  status        FeedQueueStatus   @default(pending)
