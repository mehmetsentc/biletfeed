generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ROLE_USER
  ROLE_ORGANIZER
  ROLE_ADMIN
  ROLE_SUPER_ADMIN
}

enum OrganizerStatus {
  pending
  approved
  suspended
}

enum SupportTicketStatus {
  open
  replied
  closed
}

enum EventStatus {
  draft
  pending
  published
  cancelled
  completed
}

enum EventType {
  concert
  festival
  theatre
  sports
  workshop
  online
  other
}

enum TicketTypeEnum {
  general
  vip
  early_bird
  backstage
  student
  custom
  invitation
  media
  staff
  sponsor
}

enum EntryPolicy {
  single
  multiple
  unlimited
}

enum TicketStatus {
  active
  paused
  sold_out
}

enum OrderStatus {
  pending
  paid
  cancelled
  refunded
}

enum PurchasedTicketStatus {
  VALID
  USED
  CANCELLED
  REFUNDED
}

enum TransactionStatus {
  pending
  completed
  failed
  refunded
}

enum Currency {
  TRY
  USD
  EUR
}

enum ListingType {
  internal
  external
}

enum ExternalPlatform {
  BILETIX
  BUBILET
  BILETINO
  BILETIMO
  PASSO
  GECCE
}

enum ScrapeRunStatus {
  running
  success
  partial
  failed
}

enum InvitationStatus {
  sent
  viewed
  cancelled
}

enum InvoiceType {
  e_fatura
  e_arsiv
  proforma
  credit_note
}

enum InvoiceStatus {
  draft
  issued
  cancelled
}

enum EmailDeliveryStatus {
  queued
  sent
  delivered
  bounced
  opened
  failed
}

enum PayoutStatus {
  pending
  scheduled
  paid
  failed
}

enum ReconciliationStatus {
  pending
  reconciled
  mismatch
}

enum RevenueRecognitionStatus {
  deferred
  recognized
}

enum FeedPostStatus {
  discovered
  processing
  review
  scheduled
  published
  rejected
  archived
}

enum FeedPostType {
  concert_news
  festival_news
  music_news
  entertainment_news
  artist_news
  event_announcement
  behind_the_scenes
  event_recap
  top_list
  weekend_guide
  city_guide
  venue_guide
  ticket_alert
  trending_story
  ai_opinion
  interview
  photo_story
  video_story
  organizer_update
}

enum FeedEditorialStage {
  discovery
  duplicate_check
  analysis
  rewrite
  seo
  categorization
  tagging
  image_selection
  review
  publish
}

enum FeedMediaType {
  image
  video
  embed
  reel
}

enum FeedQueueStatus {
  pending
  processing
  completed
  failed
  rejected
  duplicate
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  firebaseUid  String    @unique @map("firebase_uid")
  email        String    @unique
  displayName  String    @map("display_name")
  photoURL     String?   @map("photo_url")
  role         UserRole  @default(ROLE_USER)
  adminPermissions String[] @default([]) @map("admin_permissions")
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  ownedOrganizer   Organizer?        @relation("UserOrganizer")
  favorites        Favorite[]
  followers        Follower[]        @relation("FollowerUser")
  venueFollows     VenueFollow[]
  notifications    Notification[]
  orders           Order[]
  purchasedTickets PurchasedTicket[]
  reviews          Review[]
  supportTickets   UserSupportTicket[]
  billingProfile   UserBillingProfile?
  invoices         Invoice[]
  feedPosts        FeedPost[]        @relation("FeedPostAuthor")
  feedLikes        FeedLike[]
  feedBookmarks    FeedBookmark[]
  feedComments     FeedComment[]
  feedViews        FeedView[]
  feedMemories     FeedMemory[]

  @@index([role])
  @@index([deletedAt])
  @@map("users")
}

model Organizer {
  id             String          @id @default(uuid()) @db.Uuid
  slug           String          @unique
  name           String
  description    String
  logo           String?
  coverImage     String?         @map("cover_image")
  status         OrganizerStatus @default(pending)
  ownerId        String          @unique @map("owner_id") @db.Uuid
  followerCount  Int             @default(0) @map("follower_count")
  commissionRate Float           @default(0.1) @map("commission_rate")
  socialLinks    Json            @default("{}") @map("social_links")
  contactEmail   String?         @map("contact_email")
  contactPhone   String?         @map("contact_phone")
  notifyEmail    Boolean         @default(true) @map("notify_email")
  notifySms          Boolean         @default(false) @map("notify_sms")
  accountHolderName  String?         @map("account_holder_name")
  verified           Boolean         @default(false)
  deletedAt          DateTime?       @map("deleted_at")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  owner          User                     @relation("UserOrganizer", fields: [ownerId], references: [id])
  events         Event[]
  followers      Follower[]               @relation("FollowerOrganizer")
  orders         Order[]
  transactions   Transaction[]
  venues         Venue[]
  supportTickets OrganizerSupportTicket[]
  invitations    EventInvitation[]
  payouts         OrganizerPayout[]
  coupons         Coupon[]
  billingProfiles OrganizerBillingProfile[]
  feedPosts       FeedPost[]

  @@index([status])
  @@index([deletedAt])
  @@map("organizers")
}

model OrganizerBillingProfile {
  id                String    @id @default(uuid()) @db.Uuid
  organizerId       String    @map("organizer_id") @db.Uuid
  label             String    @default("TRY Hesabı")
  iban              String
  currency          Currency  @default(TRY)
  companyLegalName  String    @map("company_legal_name")
  taxOffice         String    @map("tax_office")
  taxNumber         String    @map("tax_number")
  invoiceAddress    String    @map("invoice_address")
  deletedAt         DateTime? @map("deleted_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  organizer Organizer @relation(fields: [organizerId], references: [id], onDelete: Cascade)

  @@index([organizerId])
  @@index([deletedAt])
  @@map("organizer_billing_profiles")
}

model City {
  id         String    @id @default(uuid()) @db.Uuid
  slug       String    @unique
  name       String
  country    String    @default("Türkiye")
  image      String?
  eventCount Int       @default(0) @map("event_count")
  deletedAt  DateTime? @map("deleted_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  events Event[]
  venues Venue[]
  feedPosts FeedPost[]

  @@index([deletedAt])
  @@map("cities")
}

model Category {
  id          String    @id @default(uuid()) @db.Uuid
  slug        String    @unique
  name        String
  description String?
  icon        String?
  image       String?
  eventCount  Int       @default(0) @map("event_count")
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  events Event[]

  @@index([deletedAt])
  @@map("categories")
}

model Venue {
  id          String    @id @default(uuid()) @db.Uuid
  slug        String    @unique
  name        String
  address     String
  cityId      String    @map("city_id") @db.Uuid
  organizerId String?   @map("organizer_id") @db.Uuid
  latitude    Float?
  longitude   Float?
  capacity    Int?
  image       String?
  description String?
  seatPlan    Json      @default("{}") @map("seat_plan")
  eventCount  Int       @default(0) @map("event_count")
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  city      City          @relation(fields: [cityId], references: [id])
  organizer Organizer?    @relation(fields: [organizerId], references: [id])
  events    Event[]
  feedPosts FeedPost[]
  followers VenueFollow[]

  @@index([cityId])
  @@index([organizerId])
  @@index([deletedAt])
  @@map("venues")
}

model Event {
  id           String      @id @default(uuid()) @db.Uuid
  slug         String      @unique
  title        String
  description  String
  shortDescription String? @map("short_description")
  organizerId  String      @map("organizer_id") @db.Uuid
  venueId      String?     @map("venue_id") @db.Uuid
  cityId       String      @map("city_id") @db.Uuid
  categoryId   String      @map("category_id") @db.Uuid
  coverImage   String      @map("cover_image")
  gallery      String[]    @default([])
  startDate    DateTime    @map("start_date")
  endDate      DateTime    @map("end_date")
  gateOpenTime DateTime?   @map("gate_open_time")
  status       EventStatus @default(draft)
  eventType    EventType   @default(other) @map("event_type")
  isOnline     Boolean     @default(false) @map("is_online")
  onlineUrl    String?     @map("online_url")
  isFeatured   Boolean     @default(false) @map("is_featured")
  isTrending   Boolean     @default(false) @map("is_trending")
  isFree       Boolean     @default(false) @map("is_free")
  discountPercent Int?     @map("discount_percent")
  basePrice    Float       @default(0) @map("base_price")
  currency     Currency    @default(TRY)
  attendees    Int         @default(0)
  capacity     Int         @default(0)
  entryPolicy  EntryPolicy @default(single) @map("entry_policy")
  tags         String[]    @default([])
  rules        String      @default("")
  faqs         Json        @default("[]")
  seo          Json        @default("{}")
  stats        Json        @default("{\"views\":0,\"favorites\":0,\"ticketSales\":0}")
  listingType      ListingType       @default(internal) @map("listing_type")
  externalPlatform ExternalPlatform? @map("external_platform")
  externalUrl      String?           @map("external_url")
  externalEventId  String?           @map("external_event_id")
  dedupeHash       String?           @unique @map("dedupe_hash")
  lastScrapedAt    DateTime?         @map("last_scraped_at")
  deletedAt    DateTime?   @map("deleted_at")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  organizer        Organizer         @relation(fields: [organizerId], references: [id])
  venue            Venue?            @relation(fields: [venueId], references: [id])
  city             City              @relation(fields: [cityId], references: [id])
  category         Category          @relation(fields: [categoryId], references: [id])
  ticketTypes      TicketType[]
  orders           Order[]
  purchasedTickets PurchasedTicket[]
  favorites        Favorite[]
  reviews          Review[]
  invitations      EventInvitation[]
  payouts          OrganizerPayout[]
  checkIns         TicketCheckIn[]
  coupons          Coupon[]
  feedPosts        FeedPost[]
  feedMemories     FeedMemory[]
  homeBanners      HomeBanner[]

  @@index([status])
  @@index([organizerId])
  @@index([cityId])
  @@index([categoryId])
  @@index([startDate])
  @@index([isFeatured])
  @@index([isTrending])
  @@index([listingType])
  @@index([externalPlatform])
  @@index([lastScrapedAt])
  @@unique([externalPlatform, externalEventId])
  @@index([deletedAt])
  @@map("events")
}

model ScrapeRun {
  id           String           @id @default(uuid()) @db.Uuid
  status       ScrapeRunStatus  @default(running)
  startedAt    DateTime         @default(now()) @map("started_at")
  finishedAt   DateTime?        @map("finished_at")
  totalFetched Int              @default(0) @map("total_fetched")
  totalCreated Int              @default(0) @map("total_created")
  totalUpdated Int              @default(0) @map("total_updated")
  totalSkipped Int              @default(0) @map("total_skipped")
  totalDeduped Int              @default(0) @map("total_deduped")
  errors       Json             @default("[]")
  platformStats Json            @default("{}") @map("platform_stats")
  createdAt    DateTime         @default(now()) @map("created_at")

  @@index([startedAt])
  @@map("scrape_runs")
}

model TicketType {
  id            String         @id @default(uuid()) @db.Uuid
  eventId       String         @map("event_id") @db.Uuid
  name          String
  description   String         @default("")
  type          TicketTypeEnum @default(general)
  price         Float
  currency      Currency       @default(TRY)
  quantity      Int
  sold          Int            @default(0)
  capacity      Int
  saleStartDate DateTime       @map("sale_start_date")
  saleEndDate   DateTime       @map("sale_end_date")
  status            TicketStatus   @default(active)
  showLowStockBadge Boolean        @default(false) @map("show_low_stock_badge")
  deletedAt         DateTime?      @map("deleted_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  event            Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  purchasedTickets PurchasedTicket[]
  orderItems       OrderItem[]
  invitations      EventInvitation[]

  @@index([eventId])
  @@index([status])
  @@index([deletedAt])
  @@map("ticket_types")
}

model Order {
  id              String      @id @default(uuid()) @db.Uuid
  userId          String      @map("user_id") @db.Uuid
  eventId         String      @map("event_id") @db.Uuid
  organizerId     String      @map("organizer_id") @db.Uuid
  subtotal        Float
  discount        Float       @default(0)
  commission      Float       @default(0)
  total           Float
  status          OrderStatus @default(pending)
  paymentProvider String      @map("payment_provider")
  paymentId       String?     @map("payment_id")
  paymentSessionId String?    @map("payment_session_id")
  expiresAt       DateTime?   @map("expires_at")
  paidAt          DateTime?   @map("paid_at")
  couponCode      String?     @map("coupon_code")
  attendeeName    String?     @map("attendee_name")
  attendeeEmail   String?     @map("attendee_email")
  attendeePhone   String?     @map("attendee_phone")
  attendeeTcKimlik String?    @map("attendee_tc_kimlik")
  deletedAt       DateTime?   @map("deleted_at")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  user             User              @relation(fields: [userId], references: [id])
  event            Event             @relation(fields: [eventId], references: [id])
  organizer        Organizer         @relation(fields: [organizerId], references: [id])
  items            OrderItem[]
  purchasedTickets PurchasedTicket[]
  transactions     Transaction[]
  invoices         Invoice[]
  reconciliations  PaymentReconciliation[]
  revenueEntries   RevenueRecognition[]
  payouts          OrganizerPayout[]

  @@index([userId])
  @@index([eventId])
  @@index([status])
  @@index([deletedAt])
  @@map("orders")
}

model OrderItem {
  id         String @id @default(uuid()) @db.Uuid
  orderId    String @map("order_id") @db.Uuid
  ticketTypeId String @map("ticket_type_id") @db.Uuid
  quantity   Int
  unitPrice  Float  @map("unit_price")

  order      Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ticketType TicketType @relation(fields: [ticketTypeId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

model PurchasedTicket {
  id              String                @id @default(uuid()) @db.Uuid
  orderId         String                @map("order_id") @db.Uuid
  ticketTypeId    String                @map("ticket_type_id") @db.Uuid
  ticketCode      String                @unique @map("ticket_code")
  userId          String                @map("user_id") @db.Uuid
  eventId         String                @map("event_id") @db.Uuid
  validationToken String                @map("validation_token")
  tokenNonce      String?               @map("token_nonce")
  status          PurchasedTicketStatus @default(VALID)
  attendeeName    String?               @map("attendee_name")
  attendeeEmail   String?               @map("attendee_email")
  attendeePhone   String?               @map("attendee_phone")
  attendeeTcKimlik String?              @map("attendee_tc_kimlik")
  downloadCount   Int                   @default(0) @map("download_count")
  entryCount      Int                   @default(0) @map("entry_count")
  scannedAt       DateTime?             @map("scanned_at")
  scannedBy       String?               @map("scanned_by")
  deletedAt       DateTime?             @map("deleted_at")
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")

  order      Order             @relation(fields: [orderId], references: [id])
  ticketType TicketType        @relation(fields: [ticketTypeId], references: [id])
  user       User              @relation(fields: [userId], references: [id])
  event      Event             @relation(fields: [eventId], references: [id])
  invitation EventInvitation?
  checkIns   TicketCheckIn[]
  transfers  TicketTransfer[]
  walletPasses WalletPass[]

  @@index([userId])
  @@index([eventId])
  @@index([status])
  @@index([deletedAt])
  @@map("purchased_tickets")
}

model EventInvitation {
  id                String           @id @default(uuid()) @db.Uuid
  eventId           String           @map("event_id") @db.Uuid
  organizerId       String           @map("organizer_id") @db.Uuid
  purchasedTicketId String           @unique @map("purchased_ticket_id") @db.Uuid
  ticketTypeId      String           @map("ticket_type_id") @db.Uuid
  guestName         String           @map("guest_name")
  guestEmail        String?          @map("guest_email")
  guestPhone        String?          @map("guest_phone")
  inviteToken       String           @unique @map("invite_token")
  personalMessage   String?          @map("personal_message")
  status            InvitationStatus @default(sent)
  viewedAt          DateTime?        @map("viewed_at")
  deletedAt         DateTime?        @map("deleted_at")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  event           Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  organizer       Organizer       @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  purchasedTicket PurchasedTicket @relation(fields: [purchasedTicketId], references: [id], onDelete: Cascade)
  ticketType      TicketType      @relation(fields: [ticketTypeId], references: [id])

  @@index([eventId])
  @@index([organizerId])
  @@index([status])
  @@index([deletedAt])
  @@map("event_invitations")
}

model TicketCheckIn {
  id        String   @id @default(uuid()) @db.Uuid
  ticketId  String   @map("ticket_id") @db.Uuid
  eventId   String   @map("event_id") @db.Uuid
  checkedBy String   @map("checked_by")
  device    String?
  ipAddress String?  @map("ip_address")
  scannerId String?  @map("scanner_id")
  result    String
  createdAt DateTime @default(now()) @map("created_at")

  ticket PurchasedTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  event  Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([eventId])
  @@index([createdAt])
  @@map("ticket_check_ins")
}

model TicketTransfer {
  id          String    @id @default(uuid()) @db.Uuid
  ticketId    String    @map("ticket_id") @db.Uuid
  fromUserId  String    @map("from_user_id") @db.Uuid
  toUserId    String?   @map("to_user_id") @db.Uuid
  toEmail     String?   @map("to_email")
  status      String    @default("pending")
  createdAt   DateTime  @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")

  ticket PurchasedTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([fromUserId])
  @@index([status])
  @@map("ticket_transfers")
}

model Coupon {
  id            String    @id @default(uuid()) @db.Uuid
  code          String
  assignedLabel String?   @map("assigned_label")
  eventId       String?   @map("event_id") @db.Uuid
  organizerId String    @map("organizer_id") @db.Uuid
  type        String
  value       Float
  maxUses     Int?      @map("max_uses")
  usedCount   Int       @default(0) @map("used_count")
  minOrder    Float?    @map("min_order")
  validFrom   DateTime  @map("valid_from")
  validUntil  DateTime  @map("valid_until")
  active      Boolean   @default(true)
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  event     Event?    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  organizer Organizer @relation(fields: [organizerId], references: [id], onDelete: Cascade)

  @@unique([code, eventId])
  @@index([code])
  @@index([organizerId])
  @@index([deletedAt])
  @@map("coupons")
}

model WalletPass {
  id        String   @id @default(uuid()) @db.Uuid
  ticketId  String   @map("ticket_id") @db.Uuid
  platform  String
  passId    String?  @map("pass_id")
  status    String   @default("pending")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  ticket PurchasedTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@unique([ticketId, platform])
  @@index([ticketId])
  @@map("wallet_passes")
}

model Transaction {
  id          String            @id @default(uuid()) @db.Uuid
  orderId     String            @map("order_id") @db.Uuid
  organizerId String            @map("organizer_id") @db.Uuid
  amount      Float
  currency    Currency          @default(TRY)
  status      TransactionStatus @default(pending)
  provider    String
  providerRef String?           @map("provider_ref")
  deletedAt   DateTime?         @map("deleted_at")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  order     Order     @relation(fields: [orderId], references: [id])
  organizer Organizer @relation(fields: [organizerId], references: [id])

  @@index([orderId])
  @@index([organizerId])
  @@index([status])
  @@index([deletedAt])
  @@map("transactions")
}

model UserBillingProfile {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @unique @map("user_id") @db.Uuid
  companyName    String?  @map("company_name")
  taxOffice      String?  @map("tax_office")
  taxNumber      String?  @map("tax_number")
  billingAddress String?  @map("billing_address")
  isCorporate    Boolean  @default(false) @map("is_corporate")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_billing_profiles")
}

model Invoice {
  id              String        @id @default(uuid()) @db.Uuid
  orderId         String        @map("order_id") @db.Uuid
  userId          String        @map("user_id") @db.Uuid
  invoiceNumber   String        @unique @map("invoice_number")
  type            InvoiceType   @default(e_arsiv)
  status          InvoiceStatus @default(issued)
  buyerName       String        @map("buyer_name")
  buyerTaxNumber  String?       @map("buyer_tax_number")
  buyerTaxOffice  String?       @map("buyer_tax_office")
  buyerAddress    String?       @map("buyer_address")
  subtotalNet     Float         @map("subtotal_net")
  vatRate         Float         @map("vat_rate")
  vatAmount       Float         @map("vat_amount")
  totalGross      Float         @map("total_gross")
  currency        Currency      @default(TRY)
  issuedAt        DateTime      @default(now()) @map("issued_at")
  cancelledAt     DateTime?     @map("cancelled_at")
  eInvoiceUuid    String?       @map("e_invoice_uuid")
  metadata        Json          @default("{}")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  order  Order         @relation(fields: [orderId], references: [id])
