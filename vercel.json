{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": ["fra1"],
  "crons": [
    {
      "path": "/api/cron/scrape-events",
      "schedule": "0 18 * * *"
    },
    {
      "path": "/api/cron/newsletter-digest",
      "schedule": "0 19 * * *"
    },
    {
      "path": "/api/cron/accounting",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/event-reminders",
      "schedule": "0 7,15 * * *"
    },
    {
      "path": "/api/cron/expire-orders",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/event-reminders-2h",
      "schedule": "5 * * * *"
    },
    {
      "path": "/api/cron/gate-open-reminders",
      "schedule": "*/10 * * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
