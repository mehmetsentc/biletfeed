# BiletFeed — örnek ortam değişkenleri
# Kopyala: cp .env.example .env.local

# Veritabanı
DATABASE_URL=

# Site
NEXT_PUBLIC_APP_NAME=Bilet Feed
NEXT_PUBLIC_APP_DESCRIPTION=Etkinlik keşfet, bilet al
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_ROOT_DOMAIN=localhost:3000
NEXT_PUBLIC_CANONICAL_HOST=localhost:3000

# Alt alanlar (production)
# NEXT_PUBLIC_PANEL_URL=https://panel.biletfeed.com
# NEXT_PUBLIC_SUPPORT_URL=https://destek.biletfeed.com
# NEXT_PUBLIC_GIRIS_URL=https://giris.biletfeed.com
# NEXT_PUBLIC_ADMIN_URL=https://admin.biletfeed.com

# Firebase Client
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (veya firebase-admin.json)
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Güvenlik
NEXTAUTH_SECRET=
TICKET_SECRET_KEY=
CRON_SECRET=
SUPER_ADMIN_EMAILS=

# Redis (production önerilir)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# E-posta
RESEND_API_KEY=
RESEND_FROM_EMAIL=davetiye@biletfeed.com

# Muhasebe
ACCOUNTING_VAT_RATE=20
COMPANY_IBAN=
COMPANY_MERSIS_NO=

# Sosyal medya (footer)
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_TWITTER_URL=
NEXT_PUBLIC_YOUTUBE_URL=

# Mobil mağaza
NEXT_PUBLIC_APP_STORE_URL=
NEXT_PUBLIC_PLAY_STORE_URL=

# Özellik bayrakları
WALLET_ENABLED=false
SCRAPER_ENABLED=false
PAYMENT_PROVIDER=mock

# Ödeme (iyzico — banka anlaşması sonrası)
# IYZICO_API_KEY=
# IYZICO_SECRET_KEY=

# Google Places (organizer wizard: mekan adı → adres)
# Google Cloud → Places API (legacy) + Maps JavaScript API gerekmez; sadece Places API
# Anahtarı HTTP referrer/IP ile kısıtlayın; asla NEXT_PUBLIC_ yapmayın
GOOGLE_MAPS_API_KEY=
