# Production ortam değişkenleri (Vercel dashboard'a kopyalayın)
# Domain: biletfeed.com veya kendi domain'iniz

NEXT_PUBLIC_APP_NAME=Bilet Feed
NEXT_PUBLIC_APP_DESCRIPTION=Modern etkinlik keşif ve bilet platformu
NEXT_PUBLIC_APP_URL=https://biletfeed.com
NEXT_PUBLIC_SITE_URL=https://biletfeed.com
NEXT_PUBLIC_ROOT_DOMAIN=biletfeed.com
NEXT_PUBLIC_CANONICAL_HOST=biletfeed.com
NEXT_PUBLIC_PANEL_URL=https://panel.biletfeed.com
NEXT_PUBLIC_SUPPORT_URL=https://destek.biletfeed.com
NEXT_PUBLIC_GIRIS_URL=https://giris.biletfeed.com
NEXT_PUBLIC_ADMIN_URL=https://admin.biletfeed.com

NEXT_PUBLIC_ENABLE_SUBDOMAINS=true
NEXT_PUBLIC_ENABLE_AI=false

# Neon production connection string (pooler URL)
DATABASE_URL=

# Firebase Client — Firebase Console > Project Settings > Web App
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=biletfeed.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=biletfeed
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=biletfeed.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin — Vercel'de tek satır JSON (firebase-admin.json içeriği)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Üretim secret: openssl rand -base64 32
TICKET_SECRET_KEY=

# Vercel Cron — etkinlik scraper (21:00 TR): openssl rand -hex 32
CRON_SECRET=

# E-posta — Resend (docs/EMAIL.md)
RESEND_API_KEY=
RESEND_FROM_NAME=BiletFeed
RESEND_FROM_EMAIL=tickets@biletfeed.com
RESEND_REPLY_TO=destek@biletfeed.com
RESEND_SUPPORT_EMAIL=destek@biletfeed.com
RESEND_INVOICE_FROM=fatura@biletfeed.com
RESEND_INVITATION_FROM=davetiye@biletfeed.com

# AI etkinlik parser (OpenAI uyumlu API): docs/SCRAPER-AI-TR.md
SCRAPER_AI_ENABLED=false
SCRAPER_AI_API_KEY=
SCRAPER_AI_BASE_URL=https://api.openai.com/v1
SCRAPER_AI_MODEL=gpt-4o-mini
SCRAPER_AI_DEDUPE=false

# Google Places (organizer wizard: mekan adı → adres; sunucu tarafı)
GOOGLE_MAPS_API_KEY=
